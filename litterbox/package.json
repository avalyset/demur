{
  "name": "litterbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:cli": "tsc -p tsconfig.cli.json --noEmit",
    "batch": "tsx src/cli/batch.ts",
    "batch:smoke": "tsx src/cli/batch.ts --sessions 10 --quiet",
    "batch:baseline": "tsx src/cli/batch.ts --sessions 1000",
    "batch:continuous": "tsx src/cli/batch.ts --continuous --samples 1000 --master-seed 1",
    "rl:random": "tsx src/cli/rl-random.ts --episodes 100 --master-seed 1"
  },
  "dependencies": {
    "pixi.js": "^8.6.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.3.4",
    "vitest": "^3.1.3"
  }
}
